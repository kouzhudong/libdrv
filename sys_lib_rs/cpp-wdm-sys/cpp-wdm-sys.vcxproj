<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ProjectGuid>{6F3C9A1B-2D4E-4A8C-9B1F-0E2A3C4D5E6F}</ProjectGuid>
    <RootNamespace>cppwdmsys</RootNamespace>
    <!-- 本机仅安装了该 WDK/SDK 版本的 km 头与库 -->
    <WindowsTargetPlatformVersion>10.0.28000.0</WindowsTargetPlatformVersion>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Label="Configuration">
    <TargetVersion>Windows10</TargetVersion>
    <!-- WDK 内核驱动工具集:由它自动接入 WDK 头/库与 .sys 产出 -->
    <PlatformToolset>WindowsKernelModeDriver10.0</PlatformToolset>
    <ConfigurationType>Driver</ConfigurationType>
    <DriverType>WDM</DriverType>
    <!-- 本机未装 Spectre 缓解版内核库,关闭以免链接报错 -->
    <SpectreMitigation>false</SpectreMitigation>
    <!-- 构建期不自动测试签名(签名/加载是单独的运行期步骤,需管理员+测试证书)。见 README -->
    <SignMode>Off</SignMode>
  </PropertyGroup>

  <PropertyGroup Label="Configuration" Condition="'$(Configuration)'=='Debug'">
    <UseDebugLibraries>true</UseDebugLibraries>
  </PropertyGroup>
  <PropertyGroup Label="Configuration" Condition="'$(Configuration)'=='Release'">
    <UseDebugLibraries>false</UseDebugLibraries>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <PropertyGroup>
    <!-- 第 1 个工程产出的 Rust 静态库目录 -->
    <KernelLibDir>$(MSBuildProjectDirectory)\..\01-kernel-lib\target\release</KernelLibDir>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <WarningLevel>Level3</WarningLevel>
      <!-- 源文件含 UTF-8 中文注释,告知编译器源编码为 UTF-8(否则在 CP936 系统报 C4819) -->
      <AdditionalOptions>/utf-8 %(AdditionalOptions)</AdditionalOptions>
      <!-- 头文件就在工程目录,默认包含即可 -->
      <AdditionalIncludeDirectories>$(MSBuildProjectDirectory);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <!-- 链接 Rust 导出的静态库;kernel_lib_add 在此解析 -->
      <AdditionalDependencies>$(KernelLibDir)\kernel_lib.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClCompile Include="Driver.cpp" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="kernel_lib.h" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
